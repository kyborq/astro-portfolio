---
import type { Activity } from "../data/types";
import {
  resolveActivityCover,
  resolveActivityUrlLabel,
} from "../utils/activity";

interface Props {
  items: Activity[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <section class="section" id="activities">
      <h2 class="section-title">Активность</h2>
      {items.map((item) => {
        const cover = resolveActivityCover(item);
        const urlLabel = resolveActivityUrlLabel(item);

        return (
          <article class="activity-entry entry">
            {item.url ? (
              <a
                class="activity-cover"
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${item.title} — ${urlLabel}`}
              >
                <img
                  src={cover}
                  alt=""
                  loading="lazy"
                  width="160"
                  height="120"
                  decoding="async"
                />
              </a>
            ) : (
              <div class="activity-cover">
                <img
                  src={cover}
                  alt=""
                  loading="lazy"
                  width="160"
                  height="120"
                  decoding="async"
                />
              </div>
            )}
            <div class="activity-body">
              <div class="entry-header">
                <h3 class="entry-title">{item.title}</h3>
                <time class="entry-meta">{item.year}</time>
              </div>
              {item.role && <p class="entry-role">{item.role}</p>}
              <p class="entry-description">{item.description}</p>
              {item.url && (
                <a
                  class="activity-link"
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {urlLabel} →
                </a>
              )}
            </div>
          </article>
        );
      })}
    </section>
  )
}

<style>
  .activity-entry {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .activity-cover {
    flex-shrink: 0;
    width: 220px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: #f5f5f4;
    aspect-ratio: 16 / 9;
  }

  a.activity-cover {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  a.activity-cover:hover {
    border-color: #d6d3d1;
  }

  .activity-cover img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .activity-body {
    flex: 1;
    min-width: 0;
  }

  .activity-body .entry-description {
    margin-bottom: 0.75rem;
  }

  .activity-link {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .activity-link:hover {
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .activity-entry {
      flex-direction: column;
      gap: 1rem;
    }

    .activity-cover {
      width: 100%;
      max-width: 240px;
    }
  }
</style>
