---
import type { Profile } from '../data/types';

interface Props {
	profile: Profile;
}

const { profile } = Astro.props;

const primaryContact = profile.contacts.find((c) => c.href === profile.primaryContactHref);
const emailContact = profile.contacts.find((c) => c.href.startsWith('mailto:'));
---

<header class="intro">
	<div class="intro-top">
		<div class="intro-heading">
			<p class="intro-status">Открыт к предложениям</p>
			<h1 class="intro-name">{profile.name}</h1>
			<p class="intro-subtitle">
				{profile.title} · {profile.location}
			</p>
			<p class="intro-tagline">{profile.tagline}</p>
		</div>
		<img
			class="intro-avatar"
			src="/avatar.jpg"
			alt={profile.name}
			width="140"
			height="140"
			loading="eager"
			decoding="async"
		/>
	</div>
	<p class="intro-bio">{profile.bio}</p>
	<div class="intro-looking">
		<p class="intro-looking-label">{profile.lookingFor.label}</p>
		<ul class="intro-looking-list">
			{profile.lookingFor.items.map((item) => <li>{item}</li>)}
		</ul>
	</div>
	{
		primaryContact && (
			<div class="intro-cta">
				<a class="intro-cta-primary" href={primaryContact.href} target="_blank" rel="noopener noreferrer">
					Написать в Telegram
				</a>
				<a class="intro-cta-secondary" href={emailContact?.href ?? 'mailto:k.podyganov@mail.ru'}>
					Email
				</a>
				{profile.cv && (
					<a class="intro-cta-secondary" href={profile.cv.href} target="_blank" rel="noopener noreferrer">
						{profile.cv.label}
					</a>
				)}
			</div>
		)
	}
	<ul class="contacts">
		{
			profile.contacts.map((contact) => (
				<li>
					<span class="contacts-label">{contact.label}</span>{' '}
					<a href={contact.href} target={contact.href.startsWith('http') ? '_blank' : undefined} rel={contact.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
						{contact.value}
					</a>
				</li>
			))
		}
	</ul>
</header>

<style>
	.intro {
		margin-bottom: 0;
	}

	.intro-top {
		display: flex;
		gap: 2rem;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.5rem;
	}

	.intro-avatar {
		flex-shrink: 0;
		width: 140px;
		height: 140px;
		object-fit: cover;
		border: 1px solid var(--color-border);
		border-radius: 50%;
	}

	.intro-heading {
		flex: 1;
		min-width: 0;
	}

	.intro-status {
		margin: 0 0 0.75rem;
		font-size: 0.8125rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.intro-name {
		margin: 0 0 0.5rem;
		font-size: 1.75rem;
		font-weight: 500;
		line-height: 1.25;
		letter-spacing: -0.02em;
	}

	.intro-subtitle {
		margin: 0 0 0.75rem;
		font-size: 1rem;
		color: var(--color-muted);
	}

	.intro-tagline {
		margin: 0;
		max-width: 42ch;
		font-size: 1.0625rem;
		line-height: 1.45;
	}

	.intro-bio {
		margin: 0 0 1.5rem;
		max-width: 60ch;
	}

	.intro-looking {
		margin-bottom: 1.5rem;
		padding: 1rem 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: 4px;
		background: #fff;
	}

	.intro-looking-label {
		margin: 0 0 0.5rem;
		font-size: 0.8125rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.intro-looking-list {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.intro-looking-list li {
		margin-bottom: 0.25rem;
		font-size: 0.9375rem;
	}

	.intro-looking-list li:last-child {
		margin-bottom: 0;
	}

	.intro-cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-bottom: 1.5rem;
	}

	.intro-cta-primary,
	.intro-cta-secondary {
		display: inline-flex;
		align-items: center;
		padding: 0.625rem 1.125rem;
		font-size: 0.9375rem;
		font-weight: 500;
		line-height: 1;
		text-decoration: none;
		border-radius: 4px;
		transition: background 0.15s ease, color 0.15s ease;
	}

	.intro-cta-primary {
		color: #fff;
		background: var(--color-text);
	}

	.intro-cta-primary:hover {
		background: #44403c;
	}

	.intro-cta-secondary {
		color: var(--color-text);
		background: transparent;
		border: 1px solid var(--color-border);
	}

	.intro-cta-secondary:hover {
		background: #fff;
	}

	.contacts {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
		font-size: 0.875rem;
	}

	.contacts a {
		color: var(--color-text);
	}

	.contacts-label {
		color: var(--color-muted);
	}

	@media (max-width: 640px) {
		.intro-top {
			gap: 1.25rem;
		}

		.intro-avatar {
			width: 112px;
			height: 112px;
		}

		.intro-name {
			font-size: 1.5rem;
		}
	}
</style>
