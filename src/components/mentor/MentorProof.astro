---
import { mentor } from "../../data/mentor";

const { proof } = mentor;
---

<section class="section proof">
  <div class="proof-intro">
    <h2 class="section-label">{proof.title}</h2>
    <p class="proof-lead">{proof.intro}</p>
  </div>

  <dl class="proof-metrics">
    {
      proof.metrics.map((metric) => (
        <div class="proof-metric">
          <dt class="proof-metric-value">{metric.value}</dt>
          <dd class="proof-metric-label">{metric.label}</dd>
        </div>
      ))
    }
  </dl>

  <ul class="proof-highlights">
    {proof.highlights.map((item) => <li>{item}</li>)}
  </ul>
</section>

<style>
  .section {
    margin-top: var(--space-section);
  }

  .section-label {
    margin: 0 0 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .proof-intro {
    margin-bottom: 2.5rem;
    max-width: 52ch;
  }

  .proof-lead {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.5;
  }

  .proof-metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    margin: 0 0 2.5rem;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-border);
    overflow: hidden;
  }

  .proof-metric {
    margin: 0;
    padding: 1.5rem 1.75rem;
    background: #fff;
  }

  .proof-metric-value {
    margin: 0 0 0.5rem;
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .proof-metric-label {
    margin: 0;
    max-width: 28ch;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-muted);
  }

  .proof-highlights {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .proof-highlights li {
    position: relative;
    padding: 0.875rem 0 0.875rem 1.25rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-muted);
  }

  .proof-highlights li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .proof-metrics {
      grid-template-columns: 1fr;
    }
  }
</style>
