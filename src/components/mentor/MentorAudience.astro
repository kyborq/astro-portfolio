---
import { mentor } from "../../data/mentor";

const { audience } = mentor;
---

<section class="section audience">
  <h2 class="section-label">{audience.title}</h2>
  <p class="audience-intro">{audience.intro}</p>
  <ul class="audience-list">
    {
      audience.items.map((item) => (
        <li class="audience-item">
          <span class="audience-label">{item.label}</span>
          <p class="audience-detail">{item.detail}</p>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .section {
    margin-top: var(--space-section);
  }

  .section-label {
    margin: 0 0 1.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .audience-intro {
    margin: 0 0 2rem;
    max-width: 52ch;
    font-size: 1.0625rem;
    line-height: 1.5;
  }

  .audience-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0;
  }

  .audience-item {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1rem 2.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
  }

  .audience-item:last-child {
    padding-bottom: 0;
  }

  .audience-label {
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .audience-detail {
    margin: 0;
    max-width: 52ch;
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .audience-item {
      grid-template-columns: 1fr;
      gap: 0.375rem;
      padding: 1.25rem 0;
    }
  }
</style>
