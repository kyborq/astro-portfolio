---
interface Props {
  screenshots?: string[];
  groupId: string;
  label: string;
  variant?: "top" | "bottom";
}

const { screenshots, groupId, label, variant = "top" } = Astro.props;
const animateOnView = variant === "bottom";
---

{
  screenshots && screenshots.length > 0 && (
    <div
      class:list={["screenshot-gallery", `screenshot-gallery--${variant}`]}
      role="list"
      aria-label={`Скриншоты ${label}`}
      data-screenshot-gallery={animateOnView ? "" : undefined}
    >
      {screenshots.map((src, index) => (
        <button
          type="button"
          class="screenshot-thumb"
          role="listitem"
          data-lightbox
          data-group={groupId}
          data-src={src}
          data-alt={`Скриншот ${label}, ${index + 1} из ${screenshots.length}`}
          aria-label={`Открыть скриншот ${index + 1}: ${label}`}
        >
          <img src={src} alt="" loading="lazy" width="240" height="150" />
        </button>
      ))}
    </div>
  )
}

<style>
  .screenshot-gallery {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .screenshot-gallery--top {
    margin-bottom: 1rem;
  }

  .screenshot-gallery--bottom {
    margin-top: 1rem;
    padding-top: 1rem;
  }

  .screenshot-thumb {
    display: block;
    width: 240px;
    padding: 0;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: #f5f5f4;
    cursor: zoom-in;
    aspect-ratio: 16 / 10;
  }

  .screenshot-thumb:hover {
    border-color: #d6d3d1;
  }

  .screenshot-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
