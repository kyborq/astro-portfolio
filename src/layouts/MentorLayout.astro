---
import "../styles/global.css";
import { profile } from "../data/profile";
import { mentor } from "../data/mentor";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Менторство — Константин Подыганов",
  description = "Ментор для frontend-разработчиков: React, TypeScript, архитектура, портфолио и поиск работы.",
} = Astro.props;

const { calendly, telegram } = mentor;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="mentor-page">
      <header class="mentor-header">
        <div class="mentor-header-inner">
          <a class="mentor-brand" href="https://k-podyganov.ru">{profile.name}</a>
          <a class="mentor-header-cta" href={calendly} target="_blank" rel="noopener noreferrer">
            Записаться
          </a>
        </div>
      </header>

      <main class="mentor-main">
        <slot />
      </main>

      <footer class="mentor-footer">
        <div class="mentor-footer-inner">
          <a href="https://k-podyganov.ru">Основной сайт</a>
          <span class="mentor-footer-sep">·</span>
          <a href={telegram} target="_blank" rel="noopener noreferrer">@kyborq</a>
        </div>
      </footer>
    </div>
  </body>
</html>

<style>
  .mentor-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
  }

  .mentor-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--color-border);
    background: rgba(250, 250, 249, 0.92);
    backdrop-filter: blur(8px);
  }

  .mentor-header-inner,
  .mentor-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0.875rem 1.5rem;
  }

  .mentor-brand {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
  }

  .mentor-brand:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .mentor-header-cta {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
  }

  .mentor-header-cta:hover {
    color: var(--color-text);
  }

  .mentor-main {
    flex: 1;
    max-width: var(--content-width);
    width: 100%;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 5rem;
  }

  .mentor-footer {
    border-top: 1px solid var(--color-border);
  }

  .mentor-footer-inner {
    justify-content: center;
    padding: 1.5rem;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .mentor-footer a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .mentor-footer a:hover {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .mentor-footer-sep {
    opacity: 0.5;
  }

  @media (max-width: 640px) {
    .mentor-main {
      padding: 2.5rem 1.25rem 4rem;
    }
  }
</style>
